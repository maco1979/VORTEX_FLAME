{
    "git.ignoreLimitWarning": true,
    "python.pythonPath": "musicgen_env\\Scripts\\python.exe",

    "cSpell.enabledFiletypes": [
        "!python",
        "markdown"
    ],
    "cSpell.userWords": [
        "automations",
        "trae",
        "Chillwave",
        "Fabio",
        "FKJ",
        "vortex",
        "soul",
        "PyDev",
        "VORTEX",
        "FLAME",
        "Souls",
        "Suno",
        "LoRA"
    ],

    "python.formatting.provider": "autopep8",
    "editor.formatOnSave": true,
    "python.analysis.typeCheckingMode": "basic",

    "files.exclude": {
        "**/__pycache__": true,
        "**/.venv": true,
        "**/.git": true
    },
    "files.encoding": "utf8",
    "files.autoGuessEncoding": true
}
