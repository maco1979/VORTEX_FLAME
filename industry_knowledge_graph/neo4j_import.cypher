MATCH (n) DETACH DELETE n;

CREATE CONSTRAINT IF NOT EXISTS FOR (b:BasicScience) REQUIRE b.id IS UNIQUE;
CREATE CONSTRAINT IF NOT EXISTS FOR (t:TechScience) REQUIRE t.id IS UNIQUE;
CREATE CONSTRAINT IF NOT EXISTS FOR (i:IndustryCategory) REQUIRE i.id IS UNIQUE;
CREATE CONSTRAINT IF NOT EXISTS FOR (s:SpecificIndustry) REQUIRE s.id IS UNIQUE;
CREATE CONSTRAINT IF NOT EXISTS FOR (soul:Soul) REQUIRE soul.id IS UNIQUE;

