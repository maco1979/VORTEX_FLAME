{
  "typeCheckingMode": "basic",
  "reportMissingImports": false,
  "reportMissingModuleSource": false,
  "reportGeneralTypeIssues": "warning",
  "reportUnnecessaryTypeIgnoreComment": false,
  "exclude": [
    "**/node_modules",
    "**/__pycache__",
    "**/.git",
    "**/kb_workflow",
    "**/kb_mcp",
    "**/kb_skill",
    "**/tools",
    "**/.vf_memory",
    "**/_test_*",
    "**/_smoke_test*",
    "**/_precache_*"
  ],
  "ignore": [
    "**/kb_workflow/**",
    "**/kb_mcp/**",
    "**/kb_skill/**",
    "**/tools/**"
  ]
}
